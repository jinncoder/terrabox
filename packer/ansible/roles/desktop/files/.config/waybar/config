[
  {
    "layer": "top",
    "position": "bottom",
    "name": "main",
    "height": 42,
    "margin-top": 0,
    "margin-left": 3,
    "margin-right": 3,
    "margin-bottom": 4,
    "reload_style_on_change": true,
    "modules-left": [
      "custom/hostname",
      "tray",
      "sway/workspaces",
      "sway/window",
      "sway/scratchpad",
      "wlr/taskbar"
    ],
    "modules-center": [
      "clock"
    ],
    "modules-right": [
      "network#ethernet",
      "network#ethernet8",
      "cpu",
      "memory",
      "disk",
      "pulseaudio#output",
      "custom/power"
    ],
    "custom/hostname": {
      "format": "{}",
      "exec": "hostname",
      "interval": "once"
    },
    "sway/workspaces": {
      "disable-scroll": false,
      "all-outputs": true,
      "format": "{name}"
    },
    "sway/window": {
      "max-length": 200,
      "tooltip": false,
      "format": "{app_id}"
    },
    "clock": {
      "interval": 15,
      "format": "{:%a %d %b  %H:%M}",
      "tooltip-format": "{calendar}",
      "calendar": {
        "mode": "month",
        "weeks-pos": "right"
      }
    },
    "cpu": {
      "interval": 4,
      "format": "CPU {usage}%"
    },
    "memory": {
      "interval": 4,
      "format": "MEM {percentage}%"
    },
    "disk": {
      "interval": 60,
      "format": "SSD {percentage_used}%"
    },
    "network#ethernet": {
      "interface": "enp0s3",
      "interval": 1,
      "format-disconnected": "",
      "format": "{ipaddr} {bandwidthTotalBits}",
      "tooltip-format": "{ifname} {ipaddr}/{cidr} {bandwidthUpBits} {bandwidthDownBits}"
    },
    "network#ethernet8": {
      "interface": "enp0s8",
      "interval": 1,
      "format-disconnected": "",
      "format": "{ipaddr} {bandwidthTotalBits}",
      "tooltip-format": "{ifname} {ipaddr}/{cidr} {bandwidthUpBits} {bandwidthDownBits}"
    },
    "pulseaudio#output": {
      "format": "♪ {volume}%",
      "format-muted": "♪ —",
      "on-click-middle": "pavucontrol",
      "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
      "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
      "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
    },
    "custom/power": {
      "format": " ⏻ ",
      "on-click": "exec ~/.config/fuzzel/power-menu.sh",
      "tooltip": false
    },
    "wlr/taskbar": {
      "all-outputs": false,
      "format": "{icon}",
      "on-click": "activate",
      "active-first": true,
      "icon-size": 28,
      "tooltip": false
    },
    "tray": {
      "icon-size": 18,
      "spacing": 2
    }
  }
]
